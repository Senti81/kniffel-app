<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.coin.kniffel.controller.crud.GameCrudController">

    <center>
        <TableView fx:id="gameTableView" prefWidth="900">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="60" text="ID" />
                <TableColumn fx:id="numberColumn" prefWidth="60" text="Nr" />
                <TableColumn fx:id="yearColumn" prefWidth="80" text="Jahr" />
                <TableColumn fx:id="dateColumn" prefWidth="120" text="Datum" />
                <TableColumn fx:id="createdAtColumn" prefWidth="160" text="Erstellt" />
                <TableColumn fx:id="updatedAtColumn" prefWidth="160" text="Aktualisiert" />
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="BOTTOM_RIGHT" spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Button fx:id="deleteButton" onAction="#handleDelete" text="Löschen" />
        </HBox>
    </bottom>

</BorderPane>
